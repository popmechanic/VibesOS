# OS files
.DS_Store

# Dependencies
node_modules/

# Claude config (user-specific, except shared rules)
.claude/*
!.claude/rules/
!.claude/agents/

# Test outputs (generated by riff)
riff-*/
RANKINGS.md

# Build output (gitignored by default)
# Shipped artifacts are explicitly un-ignored so they're tracked in git
/build/*
!/build/design-tokens.txt
!/build/design-tokens.css
!/build/vibes-menu.js

# Plan files
PLUGIN-PLAN.md

# Test directory (local testing only)
/test/
test-output/
test-sandbox/
test-vibes/
test-app/

# Local superpowers clone
superpowers/
.worktrees/

# Netlify deploy artifacts
.netlify-deploy/

# Wrangler local state
.wrangler/

# Design mockups (not part of plugin)
designs/

# Binary assets (audio, large media)
*.mp3

# Icon mask stamp (build cache)
.mask-stamp

# Timestamped backups from assembly
*.bak.jsx
*.bak.html

# Assembled app (build artifact from assemble.js)
index.html

.dev.vars*
!.dev.vars.example
!.env.example

package-lock.json

# Scratch files (generated by sessions, not part of plugin)
.superpowers/

# Working app.jsx in project root (generated during editing)
/app.jsx
